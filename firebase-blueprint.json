    "User": {
      "title": "User",
      "description": "User account information and permissions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "avatar": { "type": "string" },
        "permissions": {
          "type": "object",
          "properties": {
            "canCreate": { "type": "boolean" },
            "canEdit": { "type": "boolean" },
            "canApprove": { "type": "boolean" },
            "canVerify": { "type": "boolean" }
